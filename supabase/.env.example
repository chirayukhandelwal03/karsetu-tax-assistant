# ──────────────────────────────────────────────────────────────────────────────
# supabase/.env.example
#
# Copy this file to supabase/.env (git-ignored) and fill in real values.
# These values are loaded by `supabase functions serve --env-file supabase/.env`
# during LOCAL development ONLY.
#
# For PRODUCTION, set secrets via the Supabase CLI:
#   supabase secrets set GOOGLE_AI_API_KEY=<value>
#
# ──────────────────────────────────────────────────────────────────────────────

# Google AI (Gemini) key — used by both compute-tax and parse-documents
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
