# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to source control.

# Your Supabase project URL (found in Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/publishable key (Settings → API → "anon public")
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>

# ── Edge Function secrets (set via Supabase dashboard, NOT in .env files) ───
# In the Supabase dashboard: Edge Functions → Secrets → Add new secret
#
#   GOOGLE_AI_API_KEY = <your Gemini API key>
#
# Get a free Gemini key at: https://aistudio.google.com/app/apikey
# Required by: compute-tax, parse-documents
